<Window
    x:Class="HornetStudio.Editor.Widgets.AttachItemsEditorDialogWindow"
    x:Name="Root"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:HornetStudio.Editor.Controls"
    xmlns:viewModels="using:HornetStudio.Editor.ViewModels"
    Width="520"
    MinWidth="480"
    MinHeight="220"
    MaxHeight="760"
    SizeToContent="Height"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner"
    Title="Attach Items"
    Background="{Binding DialogBackground, ElementName=Root}">
  <Window.Styles>
    <Style Selector="Button.dialog-button">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="Background" Value="{Binding ButtonBackground, ElementName=Root}" />
      <Setter Property="BorderBrush" Value="{Binding ButtonBorderBrush, ElementName=Root}" />
      <Setter Property="Foreground" Value="{Binding ButtonForeground, ElementName=Root}" />
    </Style>
    <Style Selector="ComboBox.dialog-field /template/ ToggleButton">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{Binding PrimaryTextBrush, ElementName=Root}" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="ComboBox.dialog-field /template/ PathIcon">
      <Setter Property="Foreground" Value="{Binding PrimaryTextBrush, ElementName=Root}" />
    </Style>
    <Style Selector="ComboBox.dialog-field /template/ Path">
      <Setter Property="Fill" Value="{Binding PrimaryTextBrush, ElementName=Root}" />
    </Style>
    <Style Selector="CheckBox">
      <Setter Property="Foreground" Value="{Binding PrimaryTextBrush, ElementName=Root}" />
      <Setter Property="FontSize" Value="12" />
    </Style>
  </Window.Styles>
  <controls:EditorShellControl
      Margin="16"
      ShellBackground="{Binding DialogBackground, ElementName=Root}"
      ShellBorderBrush="{Binding BorderColor, ElementName=Root}"
      ShellBorderThickness="1"
      ShellCornerRadius="10"
      ShellPadding="14"
      ShowHeader="True"
      ShowFooter="True"
      HeaderPadding="0,0,0,10">
    <controls:EditorShellControl.HeaderContent>
      <StackPanel>
        <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="{Binding PrimaryTextBrush, ElementName=Root}" Text="Attach Items" />
        <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{Binding SecondaryTextBrush, ElementName=Root}" Text="Select which runtime items should be attached to the UI." TextWrapping="Wrap" />
      </StackPanel>
    </controls:EditorShellControl.HeaderContent>

    <controls:EditorShellControl.BodyContent>
      <Border Background="{Binding EditorDialogSectionContentBackground, ElementName=Root}"
              BorderBrush="{Binding BorderColor, ElementName=Root}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="10">
        <Grid RowDefinitions="Auto,*">
          <Grid ColumnDefinitions="28,220,*,90,72"
                Margin="0,0,0,8">
            <TextBlock Grid.Column="1"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{Binding SecondaryTextBrush, ElementName=Root}"
                       Text="Name" />
            <TextBlock Grid.Column="2"
                       Margin="8,0,0,0"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{Binding SecondaryTextBrush, ElementName=Root}"
                       Text="Source" />
            <TextBlock Grid.Column="3"
                       HorizontalAlignment="Right"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{Binding SecondaryTextBrush, ElementName=Root}"
                       Text="Interval"
                       IsVisible="{Binding ShowIntervalColumn}" />
          </Grid>

          <TextBlock Grid.Row="1"
                     Margin="0,12,0,12"
                     FontSize="12"
                     Foreground="{Binding SecondaryTextBrush, ElementName=Root}"
                     Text="{Binding EmptyRowsMessage}"
                     TextWrapping="Wrap"
                     IsVisible="{Binding ShowEmptyRowsMessage}" />

          <ScrollViewer Grid.Row="1" MaxHeight="420" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Rows}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="viewModels:AttachItemEditorRow">
                  <Grid Margin="0,0,0,6" ColumnDefinitions="28,220,*,90,72">
                    <CheckBox Grid.Column="0"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Center"
                              IsChecked="{Binding IsAttached, Mode=TwoWay}"
                              IsEnabled="{Binding CanAttach}"
                              IsVisible="{Binding CanAttach}" />

                    <TextBlock Grid.Column="1"
                               Margin="{Binding IndentMargin}"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Text="{Binding Name}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap" />

                    <TextBlock Grid.Column="2"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Text="{Binding Source}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap" />

                    <StackPanel Grid.Column="3"
                                Orientation="Horizontal"
                                Spacing="4"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                IsVisible="{Binding DataContext.ShowIntervalColumn, RelativeSource={RelativeSource AncestorType=Window}}">
                      <TextBlock Text="ms"
                                 VerticalAlignment="Center"
                                 FontSize="11" />
                      <TextBox Width="60"
                               Text="{Binding IntervalMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               HorizontalContentAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="11" />
                    </StackPanel>

                    <Button Grid.Column="4"
                            Classes="dialog-button"
                            Margin="8,0,0,0"
                            Padding="8,4"
                            HorizontalAlignment="Right"
                            Content="Remove"
                            Click="OnRemoveMissingClicked"
                            IsVisible="{Binding CanRemoveMissing}" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>
    </controls:EditorShellControl.BodyContent>

    <controls:EditorShellControl.FooterContent>
      <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
        <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" Spacing="8">
          <Button Classes="dialog-button"
                  Content="{Binding ToggleSelectionButtonText}"
                  Click="OnToggleSelectionClicked" />
          <Button Classes="dialog-button"
                  Content="Add Demo Module"
                  Click="OnAddDemoModuleClicked"
                  IsVisible="{Binding ShowAddDemoModuleButton}"
                  IsEnabled="{Binding CanOpenDemoModules}" />
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
          <Button Classes="dialog-button" Content="Save" Click="OnSaveClicked" />
          <Button Classes="dialog-button" Content="Cancel" Click="OnCancelClicked" />
        </StackPanel>
      </Grid>
    </controls:EditorShellControl.FooterContent>
  </controls:EditorShellControl>
</Window>
