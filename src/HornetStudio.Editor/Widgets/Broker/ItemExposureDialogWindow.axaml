<Window
    x:Class="HornetStudio.Editor.Widgets.ItemExposureDialogWindow"
    x:Name="Root"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:HornetStudio.Editor.Controls"
    xmlns:viewModels="using:HornetStudio.Editor.Widgets"
    Width="900"
    MinWidth="820"
    Height="620"
    MinHeight="560"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner"
    Title="{Binding TitleText}"
    Background="{Binding DialogBackground}">
  <Window.Styles>
    <Style Selector="Button.dialog-button">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="Background" Value="{Binding ButtonBackground}" />
      <Setter Property="BorderBrush" Value="{Binding ButtonBorderBrush}" />
      <Setter Property="Foreground" Value="{Binding ButtonForeground}" />
    </Style>
  </Window.Styles>

  <controls:EditorShellControl Margin="16"
                               ShellBackground="{Binding DialogBackground}"
                               ShellBorderBrush="{Binding BorderColor}"
                               ShellBorderThickness="1"
                               ShellCornerRadius="10"
                               ShellPadding="16"
                               ShowHeader="True"
                               ShowFooter="True">
    <controls:EditorShellControl.HeaderContent>
      <StackPanel>
        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{Binding PrimaryTextBrush}" Text="{Binding TitleText}" />
        <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{Binding SecondaryTextBrush}" Text="{Binding DescriptionText}" TextWrapping="Wrap" />
      </StackPanel>
    </controls:EditorShellControl.HeaderContent>

    <controls:EditorShellControl.BodyContent>
      <Grid ColumnDefinitions="320,*">
        <Border Grid.Column="0"
                Margin="0,0,12,0"
                Background="{Binding SectionBackground}"
                BorderBrush="{Binding BorderColor}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10">
          <Grid RowDefinitions="Auto,*">
            <TextBlock FontSize="12" Foreground="{Binding SecondaryTextBrush}" Text="Selected broker item." TextWrapping="Wrap" />
            <ListBox Grid.Row="1"
                     Margin="0,10,0,0"
                     ItemsSource="{Binding Rows}"
                     SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                     Background="{Binding EditorBackground}"
                     BorderBrush="{Binding BorderColor}">
              <ListBox.ItemTemplate>
                <DataTemplate DataType="viewModels:ItemExposureEditorRow">
                  <Border Padding="8" Margin="0,0,0,6" CornerRadius="6" Background="Transparent">
                    <StackPanel Spacing="2">
                      <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{Binding DataContext.PrimaryTextBrush, ElementName=Root}" Text="{Binding DisplayName}" />
                      <TextBlock FontSize="11" Foreground="{Binding DataContext.SecondaryTextBrush, ElementName=Root}" Text="{Binding Summary}" TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
        </Border>

        <Border Grid.Column="1"
                Background="{Binding SectionBackground}"
                BorderBrush="{Binding BorderColor}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
          <Grid>
            <TextBlock IsVisible="{Binding ShowEmptyState}"
                       Foreground="{Binding SecondaryTextBrush}"
                       Text="No broker item is selected."
                       TextWrapping="Wrap" />

            <ScrollViewer IsVisible="{Binding HasSelectedRow}" VerticalScrollBarVisibility="Auto">
              <StackPanel Spacing="12">
                <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                  <TextBlock VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Item" />
                  <TextBox Grid.Column="1" Margin="10,0,0,0" IsReadOnly="True" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding SelectedRow.ItemPath}" />

                  <TextBlock Grid.Row="1" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Format" />
                  <ComboBox Grid.Row="1" Grid.Column="1" Margin="10,8,0,0" ItemsSource="{Binding FormatOptions}" SelectedItem="{Binding SelectedRow.SelectedFormatKind, Mode=TwoWay}" />

                  <TextBlock Grid.Row="2" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="FormatProperty" />
                  <TextBox Grid.Row="2" Grid.Column="1" Margin="10,8,0,0" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding SelectedRow.FormatProperty, Mode=TwoWay}" />

                  <TextBlock Grid.Row="3" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Unit" />
                  <TextBox Grid.Row="3" Grid.Column="1" Margin="10,8,0,0" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding SelectedRow.Unit, Mode=TwoWay}" />

                  <TextBlock Grid.Row="4" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Bit Count" />
                  <TextBox Grid.Row="4" Grid.Column="1" Margin="10,8,0,0" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding SelectedRow.BitCountText, Mode=TwoWay}" />

                  <TextBlock Grid.Row="5" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Expose Bits" />
                  <CheckBox Grid.Row="5" Grid.Column="1" Margin="10,8,0,0" IsChecked="{Binding SelectedRow.ExposeBits, Mode=TwoWay}" VerticalAlignment="Center" />

                  <TextBlock Grid.Row="6" Margin="0,8,0,0" VerticalAlignment="Top" Foreground="{Binding PrimaryTextBrush}" Text="Bit Labels" IsVisible="{Binding SelectedRow.ExposeBits}" />
                  <TextBox Grid.Row="6" Grid.Column="1"
                           Margin="10,8,0,0"
                           MinHeight="120"
                           AcceptsReturn="True"
                           VerticalContentAlignment="Top"
                           Background="{Binding EditorBackground}"
                           BorderBrush="{Binding BorderColor}"
                           Foreground="{Binding EditorForeground}"
                           Text="{Binding SelectedRow.BitLabels, Mode=TwoWay}"
                           Watermark="Bit0=Ready&#10;Bit1=Fault"
                           IsVisible="{Binding SelectedRow.ExposeBits}" />
                </Grid>

                <TextBlock FontSize="12" Foreground="#B42318" Text="{Binding ErrorMessage}" TextWrapping="Wrap" />
              </StackPanel>
            </ScrollViewer>
          </Grid>
        </Border>
      </Grid>
    </controls:EditorShellControl.BodyContent>

    <controls:EditorShellControl.FooterContent>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
        <Button Classes="dialog-button" Content="Save" Click="OnSaveClicked" />
        <Button Classes="dialog-button" Content="Cancel" Click="OnCancelClicked" />
      </StackPanel>
    </controls:EditorShellControl.FooterContent>
  </controls:EditorShellControl>
</Window>
