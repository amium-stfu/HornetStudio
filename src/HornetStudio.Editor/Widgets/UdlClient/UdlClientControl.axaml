<editorUi:EditorTemplateControl
    x:Class="HornetStudio.Editor.Widgets.UdlClientControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:HornetStudio.Editor.Widgets"
    xmlns:editorUi="using:HornetStudio.Editor.Controls">
  <controls:UdlClientControl.HeaderActionsContent>
    <Grid ColumnDefinitions="Auto">
      <Button Padding="0"
            Background="Transparent"
            BorderBrush="Transparent"
            BorderThickness="0"
            Cursor="Hand"
              HorizontalAlignment="Left"
              IsEnabled="{Binding CanToggleConnection, RelativeSource={RelativeSource AncestorType=controls:UdlClientControl}}"
              Click="OnToggleConnectionClicked"
              PointerPressed="OnInteractivePointerPressed">
        <Border Background="{Binding ConnectionStatusBackground, RelativeSource={RelativeSource AncestorType=controls:UdlClientControl}}"
                CornerRadius="6"
                Padding="6,2">
          <TextBlock FontSize="11"
                     FontWeight="SemiBold"
                     Foreground="{Binding ConnectionStatusForeground, RelativeSource={RelativeSource AncestorType=controls:UdlClientControl}}"
                     Text="{Binding ConnectionStateText, RelativeSource={RelativeSource AncestorType=controls:UdlClientControl}}" />
        </Border>
      </Button>
    </Grid>
  </controls:UdlClientControl.HeaderActionsContent>

  <controls:UdlClientControl.BodyContent>
    <Border Padding="10,8"
            Background="{Binding EffectiveBodyBackgroundBrush}"
            BorderBrush="{Binding EffectiveBodyBorderBrush}"
            BorderThickness="{Binding EffectiveBodyBorderThickness}"
            CornerRadius="10">
      <Grid RowDefinitions="Auto,*">
        <StackPanel Grid.Row="0" Margin="0,0,0,8" Spacing="4">
          <TextBlock FontSize="12"
                     FontWeight="SemiBold"
                     Foreground="{Binding EffectiveBodyForegroundBrush}"
                     Text="{Binding SocketText, RelativeSource={RelativeSource AncestorType=controls:UdlClientControl}}" />
          <TextBlock FontSize="11"
                     Foreground="{Binding EffectiveBodyForegroundBrush}"
                     Text="{Binding ConnectionStateText, RelativeSource={RelativeSource AncestorType=controls:UdlClientControl}}"
                     TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="1" RowDefinitions="*,*">
          <Border Grid.Row="0"
                  Margin="0,0,0,5"
                  Padding="8"
                  Background="{Binding EffectiveBodyBackgroundBrush}"
                  BorderBrush="{Binding EffectiveBodyBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="8">
            <Grid RowDefinitions="Auto,*">
              <Grid Grid.Row="0"
                    Margin="0,0,0,6"
                    ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{Binding EffectiveBodyForegroundBrush}"
                           Text="Received Items"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Margin="6,0,0,0"
                        Padding="8,2"
                        Classes="toolbar"
                        Click="OnAddDemoClicked"
                        IsVisible="{Binding CanAddDemo, RelativeSource={RelativeSource AncestorType=controls:UdlClientControl}}"
                        IsEnabled="{Binding CanAddDemo, RelativeSource={RelativeSource AncestorType=controls:UdlClientControl}}">
                  <TextBlock FontSize="11" Text="AddDemo" />
                </Button>
                <ToggleButton Grid.Column="2"
                              Margin="6,0,0,0"
                              Padding="8,2"
                              Classes="toolbar"
                              Click="OnToggleAllReceivedItemsClicked"
                              IsChecked="{Binding AreAllReceivedItemsAttached, RelativeSource={RelativeSource AncestorType=controls:UdlClientControl}}"
                              IsEnabled="{Binding CanToggleAllReceivedItems, RelativeSource={RelativeSource AncestorType=controls:UdlClientControl}}">
                  <TextBlock FontSize="11" Text="All" />
                </ToggleButton>
              </Grid>
              <Grid Grid.Row="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                  <ItemsControl ItemsSource="{Binding ReceivedItems, RelativeSource={RelativeSource AncestorType=controls:UdlClientControl}}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Margin="0,0,0,6"
                                Padding="6,4"
                                Background="{Binding RowBackground}"
                                BorderBrush="{Binding RowBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                ToolTip.Tip="{Binding ToolTipText}">
                          <Grid ColumnDefinitions="Auto,*,Auto"
                                VerticalAlignment="Center">
                            <Border Width="10"
                                    Height="10"
                                    CornerRadius="999"
                                    Background="{Binding StatusIndicatorBrush}"
                                    VerticalAlignment="Center"
                                    Margin="0,0,8,0" />
                            <TextBlock Grid.Column="1"
                                       FontSize="12"
                                       Foreground="{Binding PrimaryForeground}"
                                       Text="{Binding PathText}"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="2"
                                    Padding="8,2"
                                    Classes="toolbar"
                                    Click="OnAttachReceivedItemClicked"
                                    CommandParameter="{Binding .}"
                                    IsEnabled="{Binding CanExecuteAction}">
                              <TextBlock FontSize="11" Text="{Binding ActionText}" />
                            </Button>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
                <TextBlock FontSize="11"
                           Foreground="{Binding EffectiveMutedForegroundBrush}"
                           Text="No received runtime items available. Connect the client or enable demo modules."
                           IsVisible="{Binding HasNoReceivedItems, RelativeSource={RelativeSource AncestorType=controls:UdlClientControl}}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="12" />
              </Grid>
            </Grid>
          </Border>

          <Border Grid.Row="1"
                  Margin="0,5,0,0"
                  Padding="8"
                  Background="{Binding EffectiveBodyBackgroundBrush}"
                  BorderBrush="{Binding EffectiveBodyBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="8">
            <Grid RowDefinitions="Auto,*">
              <TextBlock Grid.Row="0"
                         Margin="0,0,0,6"
                         FontSize="12"
                         FontWeight="SemiBold"
                         Foreground="{Binding EffectiveBodyForegroundBrush}"
                         Text="Attached Items" />
              <Grid Grid.Row="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                  <ItemsControl ItemsSource="{Binding AttachedItems, RelativeSource={RelativeSource AncestorType=controls:UdlClientControl}}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Margin="0,0,0,6"
                                Padding="6,4"
                                Background="{Binding RowBackground}"
                                BorderBrush="{Binding RowBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                ToolTip.Tip="{Binding ToolTipText}">
                          <Grid ColumnDefinitions="Auto,*,Auto"
                                VerticalAlignment="Center">
                            <Border Width="10"
                                    Height="10"
                                    CornerRadius="999"
                                    Background="{Binding StatusIndicatorBrush}"
                                    VerticalAlignment="Center"
                                    Margin="0,0,8,0" />
                            <TextBlock Grid.Column="1"
                                       FontSize="12"
                                       Foreground="{Binding PrimaryForeground}"
                                       Text="{Binding PathText}"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap"
                                       VerticalAlignment="Center" />
                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        Spacing="6">
                              <Button Padding="8,2"
                                      Classes="toolbar"
                                      Click="OnEditAttachedItemClicked"
                                      CommandParameter="{Binding .}"
                                      IsEnabled="{Binding CanEdit}">
                                <TextBlock FontSize="11" Text="Edit" />
                              </Button>
                              <Button Padding="8,2"
                                      Classes="toolbar"
                                      Click="OnDetachAttachedItemClicked"
                                      CommandParameter="{Binding .}"
                                      IsEnabled="{Binding CanDetach}">
                                <TextBlock FontSize="11" Text="Detach" />
                              </Button>
                            </StackPanel>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
                <TextBlock FontSize="11"
                           Foreground="{Binding EffectiveMutedForegroundBrush}"
                           Text="No UI items attached. Use AttachToUi to select received runtime items."
                           IsVisible="{Binding HasNoAttachedItems, RelativeSource={RelativeSource AncestorType=controls:UdlClientControl}}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="12" />
              </Grid>
            </Grid>
          </Border>
        </Grid>
      </Grid>
    </Border>
  </controls:UdlClientControl.BodyContent>

  <controls:UdlClientControl.FooterContent>
    <Border Padding="8,4">
      <TextBlock FontSize="11"
                 Foreground="{Binding EffectiveFooterForegroundBrush}"
                 Text="{Binding Footer}"
                 TextWrapping="Wrap" />
    </Border>
  </controls:UdlClientControl.FooterContent>
</editorUi:EditorTemplateControl>
