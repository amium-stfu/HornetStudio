<Window
    x:Class="Item.Server.Monitor.MainWindow"
    x:Name="Root"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:Item.Server.Monitor.ViewModels"
    Width="1380"
    Height="860"
    MinWidth="940"
    MinHeight="560"
    Background="#E5E7EB"
    Foreground="#0F172A"
    Title="Item Server Monitor">
  <Window.Styles>
    <Style Selector="ItemsControl.monitor-tree">
      <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="Border.monitor-tree-row">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Margin" Value="0,1,0,1" />
      <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="Border.monitor-tree-row.hovered">
      <Setter Property="Background" Value="#E2E8F0" />
    </Style>

    <Style Selector="Border.monitor-tree-row.selected">
      <Setter Property="Background" Value="#DBEAFE" />
    </Style>

    <Style Selector="TextBox.monitor-input">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="#0F172A" />
      <Setter Property="BorderBrush" Value="#94A3B8" />
    </Style>

    <Style Selector="ComboBox.monitor-input">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="#0F172A" />
      <Setter Property="BorderBrush" Value="#94A3B8" />
    </Style>

    <Style Selector="Button.toolbar-action">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="#0F172A" />
      <Setter Property="BorderBrush" Value="#94A3B8" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Button.toolbar-action:pointerover">
      <Setter Property="Background" Value="#E2E8F0" />
    </Style>

    <Style Selector="ToggleButton.toolbar-action">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="#0F172A" />
      <Setter Property="BorderBrush" Value="#94A3B8" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="ToggleButton.toolbar-action:checked">
      <Setter Property="Background" Value="#DCEAFE" />
      <Setter Property="Foreground" Value="#1D4ED8" />
      <Setter Property="BorderBrush" Value="#60A5FA" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*,Auto" Margin="16">
    <Border Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="16" Padding="16">
      <Grid ColumnDefinitions="3*,Auto,Auto,Auto,Auto" RowDefinitions="Auto,Auto">
        <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,12,0">
          <TextBlock FontSize="24" FontWeight="Bold" Text="Item Server Monitor" />
          <TextBlock Foreground="#475569"
                     Text="Read-only live view over the local item server registry mirror with manual adapter control." />
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4" Margin="0,10,12,0">
          <TextBlock FontWeight="SemiBold" Text="Search" />
          <TextBox Classes="monitor-input"
                   Watermark="Filter by path or value"
                   Text="{Binding FilterText, Mode=TwoWay}" />
        </StackPanel>

        <StackPanel Grid.Column="1" Grid.RowSpan="2" Spacing="4" VerticalAlignment="Bottom" Margin="0,0,12,0">
          <TextBlock FontWeight="SemiBold" Text="Updates" />
          <ComboBox Classes="monitor-input"
                    Width="130"
                    ItemsSource="{Binding UpdateIntervalOptions}"
                    SelectedItem="{Binding SelectedUpdateIntervalMs, Mode=TwoWay}" />
        </StackPanel>

        <StackPanel Grid.Column="2" Grid.RowSpan="2" Spacing="6" VerticalAlignment="Bottom" Margin="0,0,12,0">
          <TextBlock FontWeight="SemiBold" Text="Control" />
          <ToggleButton Classes="toolbar-action"
                        Content="Freeze"
                        IsChecked="{Binding IsPaused, Mode=TwoWay}" />
        </StackPanel>

        <StackPanel Grid.Column="3" Grid.RowSpan="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom" Margin="0,0,12,0">
          <Button Classes="toolbar-action" Command="{Binding RefreshNowCommand}" Content="Refresh now" />
          <Button Classes="toolbar-action" Command="{Binding ExpandAllCommand}" Content="Expand all" />
          <Button Classes="toolbar-action" Command="{Binding CollapseAllCommand}" Content="Collapse all" />
        </StackPanel>

        <Border Grid.Column="4" Grid.RowSpan="2" Background="#0F172A" CornerRadius="12" Padding="14" MinWidth="230">
          <StackPanel Spacing="4">
            <TextBlock Foreground="#CBD5E1" Text="Live status" />
            <TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="{Binding StatusText}" />
            <TextBlock Foreground="#93C5FD" Text="{Binding LastRefreshText}" />
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <Grid Grid.Row="1" Margin="0,14,0,14" ColumnDefinitions="2.2*,1.1*">
      <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="16" Padding="12">
        <Grid RowDefinitions="Auto,*">
          <Grid ColumnDefinitions="4*,2*" Margin="6,0,16,0">
            <TextBlock FontWeight="SemiBold" Text="Path" />
            <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="Value" />
          </Grid>

          <ScrollViewer Grid.Row="1"
                        Margin="0,8,0,0"
                        VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="MonitorTree"
                          Classes="monitor-tree"
                          ItemsSource="{Binding VisibleRows}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
              <DataTemplate DataType="viewModels:MonitorTreeRowViewModel">
                <Border Classes="monitor-tree-row"
                        Classes.hovered="{Binding IsHovered}"
                        Classes.selected="{Binding IsSelected}">
                  <Grid ColumnDefinitions="4*,2*" Margin="0,1,0,1">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <Border Width="{Binding IndentWidth}" />
                      <Grid Width="24" Height="24">
                        <Button Classes="expand-toggle"
                                Command="{Binding DataContext.ToggleExpandCommand, ElementName=Root}"
                                CommandParameter="{Binding}"
                                Content="{Binding ExpandGlyph}"
                                IsVisible="{Binding HasChildren}" />
                      </Grid>
                      <TextBlock VerticalAlignment="Center" Foreground="#0F172A" Text="{Binding DisplayName}" />
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Margin="12,0,0,0"
                               Foreground="#475569"
                               Text="{Binding ValueText}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />
                  </Grid>
                </Border>
              </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>

      <Grid Grid.Column="1" Margin="14,0,0,0" RowDefinitions="Auto,*">
        <Border Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="16" Padding="16">
          <StackPanel Spacing="12">
            <StackPanel Spacing="2">
              <TextBlock FontSize="18" FontWeight="SemiBold" Text="Adapters" />
              <TextBlock Foreground="#64748B" Text="The local item server is ready immediately. Start transports explicitly from here." TextWrapping="Wrap" />
            </StackPanel>

            <ItemsControl ItemsSource="{Binding Adapters}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="viewModels:MonitorAdapterViewModel">
                  <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="12">
                    <StackPanel Spacing="10">
                      <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="2">
                          <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                          <TextBlock Foreground="#64748B" Text="{Binding Description}" TextWrapping="Wrap" />
                        </StackPanel>
                        <Border Margin="8,0,0,0" Background="#E2E8F0" CornerRadius="999" Padding="10,4">
                          <TextBlock Foreground="{Binding StatusBrush}" FontWeight="SemiBold" Text="{Binding StatusText}" />
                        </Border>
                      </Grid>

                      <Grid ColumnDefinitions="*,90,*,Auto,Auto" RowDefinitions="Auto,Auto">
                        <StackPanel Spacing="4">
                          <TextBlock Foreground="#64748B" Text="Host" />
                          <TextBox Classes="monitor-input"
                                   IsEnabled="{Binding CanEditOptions}"
                                   Text="{Binding Host, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="8,0,0,0" Spacing="4">
                          <TextBlock Foreground="#64748B" Text="Port" />
                          <TextBox Classes="monitor-input"
                                   IsEnabled="{Binding CanEditOptions}"
                                   Text="{Binding PortText, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="8,0,0,0" Spacing="4">
                          <TextBlock Foreground="#64748B" Text="Base topic" />
                          <TextBox Classes="monitor-input"
                                   IsEnabled="{Binding CanEditOptions}"
                                   Watermark="Optional"
                                   Text="{Binding BaseTopic, Mode=TwoWay}" />
                        </StackPanel>

                        <Button Grid.Column="3"
                                Margin="8,0,0,0"
                                Classes="toolbar-action"
                                Command="{Binding StartCommand}"
                                Content="Start"
                                VerticalAlignment="Bottom" />

                        <Button Grid.Column="4"
                                Margin="8,0,0,0"
                                Classes="toolbar-action"
                                Command="{Binding StopCommand}"
                                Content="Stop"
                                VerticalAlignment="Bottom" />

                        <StackPanel Grid.Row="1" Grid.ColumnSpan="5" Orientation="Horizontal" Spacing="12">
                          <TextBlock Foreground="#64748B" Text="Endpoint" />
                          <TextBlock FontWeight="SemiBold" Text="{Binding Endpoint}" />
                        </StackPanel>
                      </Grid>

                      <Border IsVisible="{Binding HasError}" Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="10" Padding="10">
                        <TextBlock Foreground="#991B1B" Text="{Binding ErrorText}" TextWrapping="Wrap" />
                      </Border>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="0,14,0,0" Background="#FFFDF8" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="16" Padding="16">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">
              <StackPanel Spacing="2">
                <TextBlock Foreground="#64748B" Text="Selected path" />
                <TextBlock FontWeight="SemiBold" Text="{Binding SelectedPath}" TextWrapping="Wrap" />
              </StackPanel>

              <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto">
                <TextBlock Foreground="#64748B" Text="Name" />
                <TextBlock Grid.Column="1" Margin="12,0,0,0" Text="{Binding SelectedName}" />

                <TextBlock Grid.Row="1" Margin="0,8,0,0" Foreground="#64748B" Text="Value" />
                <TextBlock Grid.Row="1" Grid.Column="1" Margin="12,8,0,0" Text="{Binding SelectedValueText}" TextWrapping="Wrap" />

                <TextBlock Grid.Row="2" Margin="0,8,0,0" Foreground="#64748B" Text="Type" />
                <TextBlock Grid.Row="2" Grid.Column="1" Margin="12,8,0,0" Text="{Binding SelectedValueType}" />

                <TextBlock Grid.Row="3" Margin="0,8,0,0" Foreground="#64748B" Text="Updated" />
                <TextBlock Grid.Row="3" Grid.Column="1" Margin="12,8,0,0" Text="{Binding SelectedUpdatedText}" />
              </Grid>

              <Separator />

              <StackPanel Spacing="6">
                <TextBlock FontWeight="SemiBold" Text="Properties" />
                <ItemsControl ItemsSource="{Binding SelectedProperties}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="viewModels:MonitorPropertyRowViewModel">
                      <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Padding="10">
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                          <TextBlock Foreground="#64748B" Text="Name" />
                          <TextBlock Grid.Column="1" Margin="10,0,0,0" FontWeight="SemiBold" Text="{Binding Name}" />
                          <TextBlock Grid.Row="1" Margin="0,6,0,0" Foreground="#64748B" Text="Value" />
                          <TextBlock Grid.Row="1" Grid.Column="1" Margin="10,6,0,0" Text="{Binding ValueText}" TextWrapping="Wrap" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </StackPanel>
          </ScrollViewer>
        </Border>
      </Grid>
    </Grid>

    <Border Grid.Row="2" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="14" Padding="12">
      <TextBlock Foreground="#475569" Text="History is intentionally out of scope for version 1. The monitor always shows the latest snapshot only." />
    </Border>
  </Grid>
</Window>
