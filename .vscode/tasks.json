{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "restore-hornetstudio",
			"type": "process",
			"command": "dotnet",
			"args": [
				"restore",
				"${workspaceFolder}/HornetStudio.sln"
			],
			"problemMatcher": []
		},
		{
			"label": "build-hornetstudio-debug",
			"type": "process",
			"command": "dotnet",
			"args": [
				"build",
				"${workspaceFolder}/HornetStudio.sln",
				"-c",
				"Debug"
			],
			"problemMatcher": "$msCompile",
			"dependsOn": [
				"restore-hornetstudio"
			],
			"dependsOrder": "sequence",
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "run-hornetstudio",
			"type": "process",
			"command": "dotnet",
			"dependsOn": [
				"build-hornetstudio-debug"
			],
			"args": [
				"run",
				"--project",
				"${workspaceFolder}/src/HornetStudio/HornetStudio.csproj",
				"--no-build",
				"-c",
				"Debug"
			],
			"problemMatcher": []
		}
	]
}