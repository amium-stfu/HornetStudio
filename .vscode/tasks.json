		{
			"label": "inspect-mesh-port-owners",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"netstat -ano | findstr \":18831 :18832 :18833\""
			],
			"isBackground": false,
			"group": "test"
		},
		{
			"label": "inspect-mesh-port-owners-ps",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"Get-NetTCPConnection -State Listen | Where-Object { $_.LocalPort -in 18831,18832,18833 } | Select-Object LocalPort,OwningProcess | Format-Table -AutoSize"
			],
			"isBackground": false,
			"group": "test"
		},
		{
			"label": "kill-mesh-port-owner",
